<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posyandu_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Posyandu Digital"
                    android:textColor="@color/posyandu_primary"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/posyandu_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Posyandu Digital adalah inisiatif Bina Desa yang bertujuan untuk memodernisasi layanan kesehatan masyarakat di tingkat desa melalui teknologi mobile, memudahkan pemantauan kesehatan ibu dan anak."
                    android:textColor="@color/posyandu_text_primary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:text="Fitur Unggulan"
            android:textColor="@color/posyandu_text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Pemantauan Pertumbuhan Anak"
                    android:textColor="@color/posyandu_text_secondary"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Edukasi Kesehatan Terintegrasi"
                    android:textColor="@color/posyandu_text_secondary"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Chatbot Konsultasi Kesehatan"
                    android:textColor="@color/posyandu_text_secondary"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>